{
  "name": "nodejs-ci-app",
  "version": "1.0.0",
  "description": "Node.js application with GitHub Actions CI pipeline",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage",
    "test:ci": "jest --coverage --ci --forceExit",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\""
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "4.18.2",
    "dotenv": "16.3.1"
  },
  "devDependencies": {
    "eslint": "8.56.0",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-plugin-import": "2.29.1",
    "jest": "29.7.0",
    "nodemon": "3.0.2",
    "prettier": "3.2.4",
    "supertest": "7.1.3"
  }
}
